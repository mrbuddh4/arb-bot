# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Exchange API Configuration
SIDIORA_API_KEY=your_api_key_here
SIDIORA_API_SECRET=your_api_secret_here
SIDIORA_API_URL=https://api.sidiora.exchange

# Paxeer Network Configuration
PAXEER_RPC_URL=https://rpc.paxeer.network
PAXEER_PRIVATE_KEY=your_private_key_here

# Token Addresses (Paxeer Network)
SID_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
USDC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
UNISWAP_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000

# PostgreSQL Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=arb_bot
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_SSL=false

# Trading Configuration
PROFIT_THRESHOLD_PERCENT=1
CHECK_INTERVAL_MS=5000
AUTO_EXECUTE_TRADES=true
TRADING_PAIR=SID/USDC
MAX_TRADE_SIZE_USD=1000

# Logging
LOG_LEVEL=info
